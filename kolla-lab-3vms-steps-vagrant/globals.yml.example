---
###############################################################
# globals.yml — Lab Kolla-Ansible 3 VMs (rôles séparés)
#
# vm1 = controller   (8 Go) : APIs, DB, MQ, HAProxy
# vm2 = compute      (6 Go) : nova-compute, ovs-agent
# vm3 = network+stor (4 Go) : agents Neutron, cinder-volume LVM
###############################################################

# Distribution & version OpenStack
kolla_base_distro: "ubuntu"
openstack_release: "2024.1"

###############################################################
# Réseau
###############################################################

# VIP portée par HAProxy/Keepalived sur vm1 (loadbalancer override dans multinode)
kolla_internal_vip_address: "192.168.56.100"

# Interface management (toutes les VMs)
network_interface: "enp0s8"

# Interface provider (mappée à physnet1, utilisée par OVS sur vm2 et vm3)
neutron_external_interface: "enp0s9"

neutron_plugin_agent: "openvswitch"

###############################################################
# Compute (Nova)
###############################################################

# Émulation pure QEMU (nested KVM peu fiable sur VirtualBox)
nova_compute_virt_type: "qemu"

###############################################################
# Services activés - Stack de base
###############################################################

enable_keystone: "yes"
enable_glance: "yes"
enable_nova: "yes"
enable_neutron: "yes"
enable_placement: "yes"
enable_horizon: "yes"
enable_haproxy: "yes"
enable_mariadb: "yes"
enable_rabbitmq: "yes"
enable_memcached: "yes"

###############################################################
# Cinder (stockage bloc)
# Le backend LVM utilise le VG 'cinder-volumes' sur vm3 (/dev/sdb)
###############################################################

enable_cinder: "yes"
enable_cinder_backend_lvm: "yes"
cinder_volume_group: "cinder-volumes"

###############################################################
# Services désactivés (à activer plus tard si besoin)
###############################################################

enable_heat: "no"
enable_swift: "no"
enable_central_logging: "no"
enable_prometheus: "no"
enable_grafana: "no"
enable_ceilometer: "no"
enable_aodh: "no"
enable_gnocchi: "no"
enable_barbican: "no"
enable_designate: "no"
enable_octavia: "no"
enable_skyline: "no"
enable_magnum: "no"
enable_manila: "no"
enable_trove: "no"

###############################################################
# Divers
###############################################################

openstack_logging_debug: "False"
kolla_enable_tls_internal: "no"
kolla_enable_tls_external: "no"
