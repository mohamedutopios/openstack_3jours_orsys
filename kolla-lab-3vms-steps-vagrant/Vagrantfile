# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# Lab Kolla-Ansible Multinode (3 VMs) - Version robuste
# - vm1 (8 Go) : controller
# - vm2 (6 Go) : compute
# - vm3 (4 Go) : network + storage (avec disque Cinder)

Vagrant.configure("2") do |config|
  config.vm.box = "bento/ubuntu-22.04"
  config.vm.box_check_update = false

  # Définition centralisée des VMs
  vms = {
    "vm1" => { ip: "192.168.56.10", prov_ip: "192.168.57.10", ram: 8192, cpus: 4, cinder: false },
    "vm2" => { ip: "192.168.56.11", prov_ip: "192.168.57.11", ram: 6144, cpus: 2, cinder: false },
    "vm3" => { ip: "192.168.56.12", prov_ip: "192.168.57.12", ram: 4096, cpus: 2, cinder: true  }
  }

  vms.each do |name, cfg|
    config.vm.define name do |node|
      node.vm.hostname = name

      # Réseau management (host-only, accessible Windows)
      node.vm.network "private_network", ip: cfg[:ip]

      # Réseau provider Neutron (host-only, sans IP côté guest)
      node.vm.network "private_network",
                      ip: cfg[:prov_ip],
                      auto_config: false

      node.vm.provider "virtualbox" do |vb|
        vb.name   = "kolla-#{name}"
        vb.memory = cfg[:ram]
        vb.cpus   = cfg[:cpus]
        vb.customize ["modifyvm", :id, "--nicpromisc3", "allow-all"]
        vb.customize ["modifyvm", :id, "--nested-hw-virt", "on"]
      end

      # Disque Cinder uniquement sur vm3
      if cfg[:cinder]
        node.vm.disk :disk, size: "30GB", name: "#{name}-cinder"
      end

      # Clés SSH partagées (générées par generate-ssh.sh/ps1)
      node.vm.provision "file",
                        source: "./ssh/id_rsa",
                        destination: "/home/vagrant/.ssh/id_rsa"
      node.vm.provision "file",
                        source: "./ssh/id_rsa.pub",
                        destination: "/home/vagrant/.ssh/id_rsa.pub"

      # On dépose le hostname cible avant le bootstrap (au cas où Vagrant
      # ne l'a pas encore appliqué)
      node.vm.provision "shell",
                        inline: "echo '#{name}' > /tmp/vagrant_hostname"

      # Script de provisioning principal
      node.vm.provision "shell", path: "bootstrap.sh"
    end
  end
end
