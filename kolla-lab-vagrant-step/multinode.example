# Inventaire Kolla-Ansible Multinode - Stack de base avec Cinder
# Copier dans ~/multinode sur vm1

[control]
vm1 ansible_host=192.168.56.10 ansible_user=vagrant

[network]
vm1 ansible_host=192.168.56.10 ansible_user=vagrant

[compute]
vm1 ansible_host=192.168.56.10 ansible_user=vagrant
vm2 ansible_host=192.168.56.11 ansible_user=vagrant

[monitoring]
vm1 ansible_host=192.168.56.10 ansible_user=vagrant

[storage]
vm1 ansible_host=192.168.56.10 ansible_user=vagrant

[deployment]
localhost ansible_connection=local

# ----- Groupes hérités (ne pas modifier) -----
