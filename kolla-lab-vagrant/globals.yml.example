---
###############################################################
# globals.yml — Lab Kolla-Ansible Multinode (vm1 + vm2)
#
# Copier ce fichier dans /etc/kolla/globals.yml sur vm1
# après avoir installé Kolla-Ansible.
###############################################################

# Distribution & version OpenStack
kolla_base_distro: "ubuntu"
openstack_release: "2024.1"

###############################################################
# Réseau
###############################################################

# IP virtuelle (VIP) portée par HAProxy/Keepalived sur vm1
# Doit être LIBRE sur le subnet management (192.168.56.0/24)
# Accessible depuis Windows -> Horizon sur http://192.168.56.100
kolla_internal_vip_address: "192.168.56.100"

# Interface management/API (entre vm1 et vm2)
network_interface: "enp0s8"

# Interface provider Neutron (sans IP, host-only -> Windows peut joindre les instances)
neutron_external_interface: "enp0s9"

# Plugin Neutron : OVS classique (plus simple à debug que OVN pour un lab)
neutron_plugin_agent: "openvswitch"

###############################################################
# Compute (Nova)
###############################################################

# Émulation pure QEMU car nested KVM peu fiable sur VBox/Windows
# Les instances seront lentes mais fonctionnelles
nova_compute_virt_type: "qemu"

###############################################################
# Services activés (essentiel uniquement pour économiser la RAM)
###############################################################

enable_keystone: "yes"
enable_glance: "yes"
enable_nova: "yes"
enable_neutron: "yes"
enable_placement: "yes"
enable_horizon: "yes"
enable_haproxy: "yes"
enable_mariadb: "yes"
enable_rabbitmq: "yes"
enable_memcached: "yes"

# Services désactivés pour rester sous 6 Go RAM par VM
enable_cinder: "no"
enable_heat: "no"
enable_central_logging: "no"
enable_prometheus: "no"
enable_grafana: "no"
enable_ceilometer: "no"
enable_aodh: "no"
enable_gnocchi: "no"
enable_barbican: "no"
enable_designate: "no"
enable_octavia: "no"
enable_skyline: "no"

###############################################################
# Divers
###############################################################

# Mode debug pour les services (utile en formation)
openstack_logging_debug: "False"

# Pas de TLS pour simplifier le lab
kolla_enable_tls_internal: "no"
kolla_enable_tls_external: "no"
